<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="720.0" stylesheets="@/estilos.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.controladores.ReporteIndicadoresControlador">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header-container">
            <padding>
                <Insets bottom="15" left="25" right="25" top="15" />
            </padding>
            <Label styleClass="titulo-ventana" text="Reporte de Indicadores de Practicantes" />
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <VBox spacing="15" styleClass="panel-formulario">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label styleClass="label-seccion" text="Analizar por:" />
                    <ComboBox fx:id="cbFiltroIndicador" prefWidth="280" promptText="Selecciona un filtro" />
                    <Button fx:id="btnGenerarReportePdf" disable="true" onAction="#manejarGenerarReportePdf" styleClass="btn-guardar" text="Generar Reporte PDF" />
                </HBox>

                <Label styleClass="label-seccion" text="Distribución gráfica" />

                <BarChart fx:id="bcIndicadores" animated="false" legendVisible="false" prefHeight="320">
                    <xAxis>
                        <CategoryAxis label="Categoría" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Cantidad de practicantes" />
                    </yAxis>
                </BarChart>

                <Label styleClass="label-seccion" text="Detalle de información" />

                <TableView fx:id="tvIndicadores" prefHeight="220">
                    <columns>
                        <TableColumn fx:id="colCategoria" prefWidth="320" text="Categoría">
                            <cellValueFactory>
                                <PropertyValueFactory property="categoria" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colTotal" prefWidth="140" text="Total">
                            <cellValueFactory>
                                <PropertyValueFactory property="total" />
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>