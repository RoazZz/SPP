<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="750.0" stylesheets="@/estilos.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controladores.AutoevaluacionGenerarControlador">
    <top>
        <VBox styleClass="header-container">
            <Label styleClass="titulo-ventana" text="Generar Autoevaluación" />
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true">
            <VBox alignment="TOP_CENTER" style="-fx-padding: 30 40 30 40;" spacing="20">
                <VBox styleClass="panel-formulario" spacing="12">

                    <Label styleClass="label-seccion" text="Afirmaciones — Puntaje del 1 al 5" />

                    <Label styleClass="label-campo"
                           text="1. Cumplí con el horario y las actividades asignadas." />
                    <ComboBox fx:id="cbAfirmacion1" prefWidth="200" promptText="Selecciona puntaje" />

                    <Label styleClass="label-campo"
                           text="2. Apliqué los conocimientos adquiridos en la universidad." />
                    <ComboBox fx:id="cbAfirmacion2" prefWidth="200" promptText="Selecciona puntaje" />

                    <Label styleClass="label-campo"
                           text="3. Mostré responsabilidad y compromiso con la organización." />
                    <ComboBox fx:id="cbAfirmacion3" prefWidth="200" promptText="Selecciona puntaje" />

                    <Label styleClass="label-campo"
                           text="4. Me comuniqué de manera efectiva con mi equipo de trabajo." />
                    <ComboBox fx:id="cbAfirmacion4" prefWidth="200" promptText="Selecciona puntaje" />

                    <Label styleClass="label-campo"
                           text="5. Resolví problemas de manera autónoma durante las prácticas." />
                    <ComboBox fx:id="cbAfirmacion5" prefWidth="200" promptText="Selecciona puntaje" />

                    <Label styleClass="label-campo"
                           text="6. Entregué los reportes y documentos en tiempo y forma." />
                    <ComboBox fx:id="cbAfirmacion6" prefWidth="200" promptText="Selecciona puntaje" />

                    <Label styleClass="label-campo"
                           text="7. Mantuve una actitud profesional durante toda la práctica." />
                    <ComboBox fx:id="cbAfirmacion7" prefWidth="200" promptText="Selecciona puntaje" />

                    <Label styleClass="label-campo"
                           text="8. Aprendí nuevas habilidades durante el periodo de prácticas." />
                    <ComboBox fx:id="cbAfirmacion8" prefWidth="200" promptText="Selecciona puntaje" />

                    <Separator />

                    <Label styleClass="label-campo" text="Comentarios generales" />
                    <TextArea fx:id="txtComentarios" prefHeight="100.0"
                              promptText="Escribe tus comentarios sobre tu desempeño..."
                              wrapText="true" />

                    <Separator />

                    <Label fx:id="lblError" styleClass="label-error"
                           visible="false" managed="false" wrapText="true" />

                    <HBox alignment="CENTER_RIGHT" spacing="15">
                        <padding><Insets top="5" /></padding>
                        <Button fx:id="btnCancelar" onAction="#manejarCancelar" styleClass="btn-cancelar" text="CANCELAR" />
                        <Button fx:id="btnGenerar"  onAction="#manejarGenerar" styleClass="btn-guardar" text="GENERAR AUTOEVALUACIÓN" />
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>