<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="550.0" prefWidth="720.0" styleClass="@/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.controladores.ReporteAnadirControlador">
    <top>
        <VBox spacing="5" styleClass="header-container">
            <padding>
                <Insets bottom="15" left="25" right="25" top="15" />
            </padding>
            <children>
                <Label styleClass="titulo-ventana" text="Añadir Reporte Firmado" />
                <Label styleClass="subtitulo-ventana" text="Sube el archivo PDF con firmas y sellos originales" />
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="25">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>
                <VBox spacing="10">
                    <children>
                        <Label styleClass="label-seccion" text="Tipo de Reporte a subir:" />
                        <ComboBox fx:id="cbTipoReporte" maxWidth="Infinity" promptText="Selecciona el tipo de reporte…" />
                        <ComboBox fx:id="cbMes" promptText="Mes del reporte" maxWidth="Infinity" visible="false" managed="false" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="15" style="-fx-border-color: #ccc; -fx-border-style: dashed; -fx-padding: 25;" styleClass="subpanel-archivo">
                    <children>
                        <Label fx:id="lblNombreArchivo" maxWidth="400" styleClass="label-archivo" text="Ningún archivo seleccionado" wrapText="true" />

                        <HBox alignment="CENTER" spacing="15">
                            <children>
                                <Button onAction="#seleccionarArchivo" styleClass="btn-examinar" text="Examinar archivo…" />
                                <Button fx:id="btnVistaPrevia" managed="false"  styleClass="btn-preview" text="Vista previa" visible="false" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox fx:id="hboxValidacionArchivo" alignment="CENTER_LEFT" managed="false" spacing="8" visible="false">
                    <children>
                        <Label fx:id="lblValidacionArchivo" styleClass="label-validacion-ok" text="Archivo PDF seleccionado listo para subir" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Button fx:id="btnCancelar" styleClass="btn-cancelar" text="Cancelar" />
                <Button fx:id="btnGuardar" disable="true" onAction="#guardarReporte" styleClass="btn-guardar" text="Subir Documento" />
            </children>
        </HBox>
    </bottom>
    <stylesheets>
        <URL value="@/estilos.css" />
    </stylesheets>
</BorderPane>
