<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="750.0" prefWidth="950.0" stylesheets="@/estilos.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controladores.GenerarActividadControlador">

    <top>
        <VBox styleClass="header-container">
            <padding><Insets bottom="15" left="25" right="25" top="15" /></padding>
            <Label styleClass="titulo-ventana" text="Generar Actividad" />
            <Label styleClass="subtitulo-ventana" text="Registra una nueva actividad para un practicante" />
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 30 40 30 40;">

            <VBox spacing="15" styleClass="panel-formulario" style="-fx-max-width: Infinity;">
                <Label styleClass="label-seccion" text="Nueva Actividad" />

                <GridPane hgap="20" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                    </columnConstraints>

                    <!-- Practicante -->
                    <Label text="Practicante:" styleClass="label-campo"
                           GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2" />
                    <ComboBox fx:id="cbPracticante" maxWidth="Infinity"
                              promptText="Selecciona un practicante"
                              GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" />

                    <!-- Nombre -->
                    <Label text="Nombre de la actividad:" styleClass="label-campo"
                           GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2" />
                    <TextField fx:id="txtNombre" promptText="Ej: Análisis de requerimientos"
                               GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" />

                    <!-- Fechas -->
                    <Label text="Fecha de inicio:" styleClass="label-campo"
                           GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <DatePicker fx:id="dpFechaInicio" promptText="dd/mm/aaaa"
                                maxWidth="Infinity"
                                GridPane.columnIndex="0" GridPane.rowIndex="5" />

                    <Label text="Fecha de cierre:" styleClass="label-campo"
                           GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <DatePicker fx:id="dpFechaCierre" promptText="dd/mm/aaaa"
                                maxWidth="Infinity"
                                GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <!-- Descripción -->
                    <Label text="Descripción:" styleClass="label-campo"
                           GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.columnSpan="2" />
                    <TextArea fx:id="txtDescripcion" promptText="Descripción de la actividad"
                              prefHeight="90" wrapText="true"
                              GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2" />
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Label fx:id="lblMensajeFormulario" styleClass="label-error" wrapText="true" maxWidth="400.0" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnLimpiar" onAction="#limpiar" styleClass="btn-cancelar" text="LIMPIAR" />
                    <Button fx:id="btnGuardar" onAction="#guardar" styleClass="btn-guardar" text="GUARDAR" />
                </HBox>
            </VBox>

            <Separator />

            <VBox spacing="10" styleClass="panel-formulario" style="-fx-max-width: Infinity;">
                <Label styleClass="label-seccion" text="Actividades registradas" />
                <TableView fx:id="tablaActividades" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colIdActividad"  text="ID"           prefWidth="50"  />
                        <TableColumn fx:id="colNombre"       text="Nombre"       prefWidth="200" />
                        <TableColumn fx:id="colFechaInicio"  text="Fecha Inicio" prefWidth="120" />
                        <TableColumn fx:id="colFechaCierre"  text="Fecha Cierre" prefWidth="120" />
                        <TableColumn fx:id="colDescripcion"  text="Descripción"  prefWidth="300" />
                    </columns>
                </TableView>
            </VBox>

            <Separator />

            <HBox alignment="CENTER_RIGHT" spacing="20">
                <Label fx:id="lblMensaje" maxWidth="400.0" styleClass="label-error" wrapText="true" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnSalir" onAction="#salir" styleClass="btn-cancelar" text="SALIR" />
            </HBox>

        </VBox>
    </center>
</BorderPane>